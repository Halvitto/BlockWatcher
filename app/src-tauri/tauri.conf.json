{
  "productName": "BlockWatcher",
  "identifier": "app.blockwatcher",
  "build": {
    "beforeDevCommand": "npm run desktop:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run desktop:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "BlockWatcher",
        "url": "index.html",
        "width": 360,
        "height": 620,
        "minWidth": 300,
        "maxWidth": 380,
        "preventOverflow": {
          "width": 8,
          "height": 8
        },
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/ccusage"],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
